{
  "name": "nekudot",
  "private": true,
  "version": "0.29.0",
  "description": "A browser drawing tool with a memory - it keeps every point you draw and weaves faint threads between nearby ones, so a single gesture blooms into a web. Inspired by mrdoob's Harmony.",
  "keywords": [
    "generative-art",
    "creative-coding",
    "drawing",
    "mandala",
    "symmetry",
    "kaleidoscope",
    "canvas",
    "procedural-art",
    "harmony",
    "typescript"
  ],
  "homepage": "https://nekudot.app",
  "bugs": {
    "url": "https://github.com/barakbl/nekudot/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barakbl/nekudot.git"
  },
  "license": "GPL-2.0-only",
  "author": "Barak Bloch",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:app": "bash build.sh",
    "build:updates": "node scripts/build-updates.mjs",
    "preview": "vite preview",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "test": "vitest",
    "smoke": "node tests/smoke/smoke.mjs",
    "smoke:boot": "node tests/smoke/boot-live.mjs",
    "smoke:viewport": "node tests/smoke/viewport-live.mjs",
    "smoke:open": "node tests/smoke/canvas-open-live.mjs",
    "smoke:paste": "node tests/smoke/image-paste-live.mjs",
    "smoke:theme": "node tests/smoke/theme-live.mjs",
    "smoke:export": "node tests/smoke/export-share-live.mjs",
    "render-presets": "node tests/smoke/render-presets.mjs",
    "smoke-render": "node tests/smoke/all-render.mjs",
    "smoke-render:update": "node tests/smoke/all-render.mjs --update"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.6",
    "typescript": "^5.6.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@types/d3-quadtree": "^3.0.6",
    "d3-quadtree": "^3.0.1",
    "fflate": "^0.8.3",
    "gifenc": "^1.0.3",
    "zod": "^4.4.3"
  }
}
